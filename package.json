{
  "name": "core-game",
  "version": "0.1.12",
  "description": "CORE — a one-thumb survival-defense browser game. Logic is pure and unit-tested so an agent loop can verify its own changes.",
  "type": "module",
  "scripts": {
    "dev": "http-server -p 8080 -c-1 .",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "vitest run",
    "test:smoke": "playwright test --config playwright.config.js",
    "bump": "node scripts/bump-version.js",
    "bump:minor": "node scripts/bump-version.js minor",
    "bump:major": "node scripts/bump-version.js major"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "playwright": "^1.61.0",
    "vitest": "^2.1.0"
  }
}
